# Devil Agent Configuration
# Copy this file to .env and fill in your values

# API Configuration
DEVIL_API_KEY=your-api-key-here
DEVIL_PROVIDER=anthropic  # or "openai"
DEVIL_MODEL=claude-sonnet-4-20250514

# For OpenAI
# DEVIL_MODEL=gpt-4-turbo
# DEVIL_BASE_URL=https://api.openai.com/v1

# For Anthropic (default)
# DEVIL_BASE_URL=https://api.anthropic.com/v1

# Limits
DEVIL_MAX_CONTEXT_TOKENS=200000
DEVIL_MAX_TURNS=50

# Logging
DEVIL_VERBOSE=false
DEVIL_LOG_JSON=false

# Development
DEVIL_MOCK_MODEL=0
